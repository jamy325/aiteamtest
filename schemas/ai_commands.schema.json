{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jamy325.github.io/aiteamtest/schemas/ai_commands.schema.json",
  "title": "AI Review Proposed Commands",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "issues", "proposed_commands"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "proposed_commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command"
      }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "category", "severity", "summary"],
      "properties": {
        "issue_id": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": ["geometry", "topology", "self_intersection", "alpha", "color", "style", "constraint"]
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "summary": { "type": "string", "minLength": 1 },
        "path_id": { "type": ["string", "null"] },
        "object_id": { "type": ["string", "null"] },
        "segment_range": {
          "oneOf": [
            { "$ref": "#/$defs/segment_range" },
            { "type": "null" }
          ]
        },
        "topology_hint": { "$ref": "#/$defs/nullable_string" },
        "self_intersection_hint": { "$ref": "#/$defs/nullable_string" },
        "alpha_hint": { "$ref": "#/$defs/nullable_string" },
        "color_hint": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "nullable_string": {
      "type": ["string", "null"]
    },
    "segment_range": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "integer", "minimum": 0 }
    },
    "replace_segment_command": {
      "description": "Intent-only command. Precise geometry parameters such as start_angle, end_angle, rotation, cx, cy, r, rx, and ry are intentionally not part of this schema.",
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "path_id", "segment_range", "reason", "confidence", "requires_user_confirmation"],
      "properties": {
        "tool": {
          "type": "string",
          "enum": [
            "propose_replace_segment_with_line",
            "propose_replace_segment_with_arc",
            "propose_replace_segment_with_circle",
            "propose_replace_segment_with_ellipse"
          ]
        },
        "path_id": {
          "type": "string",
          "minLength": 1
        },
        "segment_range": {
          "$ref": "#/$defs/segment_range"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "requires_user_confirmation": {
          "type": "boolean"
        },
        "locked_anchor_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "topology_hint": { "$ref": "#/$defs/nullable_string" },
        "self_intersection_hint": { "$ref": "#/$defs/nullable_string" },
        "alpha_hint": { "$ref": "#/$defs/nullable_string" },
        "color_hint": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "batch_command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "summary", "commands", "confidence", "requires_user_confirmation"],
      "properties": {
        "tool": {
          "const": "propose_batch_refinement"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/replace_segment_command"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "requires_user_confirmation": {
          "type": "boolean"
        },
        "topology_hint": { "$ref": "#/$defs/nullable_string" },
        "self_intersection_hint": { "$ref": "#/$defs/nullable_string" },
        "alpha_hint": { "$ref": "#/$defs/nullable_string" },
        "color_hint": { "$ref": "#/$defs/nullable_string" }
      }
    },
    "command": {
      "oneOf": [
        { "$ref": "#/$defs/replace_segment_command" },
        { "$ref": "#/$defs/batch_command" }
      ]
    }
  }
}
